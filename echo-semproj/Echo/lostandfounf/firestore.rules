rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isParticipant(chatId) {
      return signedIn()
        && get(/databases/$(database)/documents/chats/$(chatId)).data.participants.hasAny([request.auth.uid]);
    }

    match /users/{userId} {
      allow read: if signedIn();
      allow create, update, delete: if signedIn() && request.auth.uid == userId;
    }

    match /items/{itemId} {
      allow read: if signedIn();
      allow create: if signedIn();
      allow update, delete: if signedIn() && resource.data.ownerId == request.auth.uid;
    }

    match /chats/{chatId} {
      allow read: if signedIn() && resource.data.participants.hasAny([request.auth.uid]);
      allow create: if signedIn()
        && request.resource.data.participants is list
        && request.resource.data.participants.size() == 2
        && request.resource.data.participants.hasAny([request.auth.uid]);
      allow update: if signedIn() && resource.data.participants.hasAny([request.auth.uid]);

      match /messages/{messageId} {
        allow read, create: if isParticipant(chatId)
          && (request.method != 'create' || request.resource.data.senderId == request.auth.uid);
        allow update, delete: if false;
      }
    }
  }
}
